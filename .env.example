# Shared
NODE_ENV=development

# API
API_PORT=4000
WEB_URL=http://localhost:3000
DATABASE_URL=postgres://sse:sse@localhost:5432/sse_platform
TYPEORM_SYNC=true
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=replace-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sse-platform.local
UPLOAD_DIR=./apps/api/uploads
MAX_UPLOAD_SIZE_MB=10
SWAGGER_PATH=docs

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=SSE Academic Collaboration Platform
